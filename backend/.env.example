# ============================================================
# GraphRAG Medical Research Assistant – Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# Never commit .env to version control.

# ----------------------------------------------------------
# LLM Provider
# ----------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ----------------------------------------------------------
# Neo4j Graph Database
# ----------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ----------------------------------------------------------
# ChromaDB Vector Store
# ----------------------------------------------------------
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=medical_research

# ----------------------------------------------------------
# Feedback Database (SQLite)
# ----------------------------------------------------------
FEEDBACK_DB_PATH=data/feedback.db

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/graphrag.log

# ----------------------------------------------------------
# Retrieval Settings
# ----------------------------------------------------------
MAX_RETRIEVAL_TOP_K=10
MIN_CONFIDENCE_THRESHOLD=0.5
